{%- liquid
  assign current_variant = product.selected_or_first_available_variant

  assign gallery_layout = section.settings.gallery_layout | default: 'thumbnails-bottom'
  assign thumbs_position_class = 'ds-image-gallery--thumbs-bottom'
  if gallery_layout == 'thumbnails-left'
    assign thumbs_position_class = 'ds-image-gallery--thumbs-left'
  endif

  assign images = product.images
  if product.featured_image
    assign first_image = product.featured_image
  else
    assign first_image = images[0]
  endif

  assign stock_status = 'in-stock'
  if current_variant.available == false
    assign stock_status = 'out-of-stock'
  elsif current_variant.inventory_management != blank and current_variant.inventory_quantity and current_variant.inventory_quantity <= 5 and current_variant.inventory_quantity > 0
    assign stock_status = 'low-stock'
  endif

  assign stock_label = 'In stock and ready to ship'
  if stock_status == 'low-stock'
    assign stock_label = 'Low stock — order soon'
  elsif stock_status == 'out-of-stock'
    assign stock_label = 'Out of stock'
  endif

  comment
    Reviews metafield support — only rendered when both aggregate
    rating and review count are set. We do not invent values; if the
    store hasn't populated these the whole block is skipped.
  endcomment
  assign review_rating = product.metafields.reviews.rating.value.rating
  assign review_count = product.metafields.reviews.rating_count | default: product.metafields.reviews.count
  assign has_reviews = false
  if section.settings.show_star_rating and review_rating and review_count
    assign has_reviews = true
  endif

  assign specifications = product.metafields.custom.specifications.value
  assign has_specs = false
  if specifications
    assign has_specs = true
  endif
-%}

<section class="ds-page-container ds-product" aria-labelledby="ProductTitle-{{ section.id }}">
  <div class="ds-product__breadcrumb">
    {% render 'breadcrumb' %}
  </div>

  <article class="ds-layout ds-layout--golden">
    {%- comment -%} ─── Gallery column (7/12) ─── {%- endcomment -%}
    <div class="ds-product__gallery">
      {%- if images.size > 0 -%}
        <div
          class="ds-image-gallery {{ thumbs_position_class }}{% if section.settings.enable_zoom %} ds-image-gallery--zoomable{% endif %}"
          data-product-gallery
        >
          <div class="ds-image-gallery__main">
            {%- for image in images -%}
              <figure
                class="ds-image-gallery__slide{% if forloop.first %} ds-image-gallery__slide--active{% endif %}"
                data-gallery-slide
                data-index="{{ forloop.index0 }}"
                {% unless forloop.first %}aria-hidden="true"{% endunless %}
              >
                {%- if forloop.first -%}
                  {% render 'responsive-image',
                    image: image,
                    alt: image.alt | default: product.title,
                    sizes: '(min-width: 1024px) 58vw, 100vw',
                    loading: 'eager',
                    fetchpriority: 'high',
                    class: 'ds-image-gallery__img'
                  %}
                {%- else -%}
                  {% render 'responsive-image',
                    image: image,
                    alt: image.alt | default: product.title,
                    sizes: '(min-width: 1024px) 58vw, 100vw',
                    loading: 'lazy',
                    class: 'ds-image-gallery__img'
                  %}
                {%- endif -%}
              </figure>
            {%- endfor -%}
          </div>

          {%- if images.size > 1 -%}
            <div
              class="ds-image-gallery__thumbs"
              role="tablist"
              aria-label="Product images"
            >
              {%- for image in images -%}
                <button
                  type="button"
                  class="ds-image-gallery__thumb{% if forloop.first %} ds-image-gallery__thumb--active{% endif %}"
                  role="tab"
                  aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                  aria-label="{{ image.alt | default: product.title | escape }} — view {{ forloop.index }} of {{ images.size }}"
                  data-gallery-thumb
                  data-index="{{ forloop.index0 }}"
                  tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
                >
                  <img
                    src="{{ image | image_url: width: 160 }}"
                    srcset="{{ image | image_url: width: 160 }} 1x, {{ image | image_url: width: 320 }} 2x"
                    alt=""
                    class="ds-image-gallery__thumb-img"
                    loading="lazy"
                    decoding="async"
                    width="80"
                    height="80"
                  >
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ─── Details column (5/12) ─── {%- endcomment -%}
    <div class="ds-product__details">
      <header class="ds-product__header">
        {%- if section.settings.show_vendor and product.vendor != blank -%}
          <span class="ds-text ds-text--sm ds-text--muted ds-product__vendor">{{ product.vendor }}</span>
        {%- endif -%}

        <h1
          id="ProductTitle-{{ section.id }}"
          class="ds-heading ds-heading--2xl ds-heading--normal ds-product__title"
        >
          {{ product.title }}
        </h1>

        {%- if has_reviews -%}
          {%- assign review_count_int = review_count | plus: 0 -%}
          {%- assign review_rating_float = review_rating | times: 1.0 -%}
          <div
            class="ds-star-rating ds-star-rating--sm ds-product__rating"
            role="img"
            aria-label="{{ review_rating_float }} out of 5 stars ({{ review_count_int }} reviews)"
          >
            <span class="ds-star-rating__stars">
              {%- for i in (1..5) -%}
                {%- assign star_diff = review_rating_float | minus: i -%}
                {%- if star_diff >= 0 -%}
                  <svg class="ds-star-rating__star ds-star-rating__star--full" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.49L10 14.26 5.06 16.7 6 11.21l-4-3.9 5.53-.8L10 1.5z" class="ds-star-rating__star-fill"/>
                  </svg>
                {%- elsif star_diff >= -0.5 -%}
                  <svg class="ds-star-rating__star ds-star-rating__star--half" viewBox="0 0 20 20" aria-hidden="true">
                    <defs>
                      <clipPath id="StarHalf-{{ section.id }}-{{ i }}">
                        <rect x="0" y="0" width="10" height="20"/>
                      </clipPath>
                    </defs>
                    <path d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.49L10 14.26 5.06 16.7 6 11.21l-4-3.9 5.53-.8L10 1.5z" class="ds-star-rating__star-bg"/>
                    <path d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.49L10 14.26 5.06 16.7 6 11.21l-4-3.9 5.53-.8L10 1.5z" clip-path="url(#StarHalf-{{ section.id }}-{{ i }})" class="ds-star-rating__star-fill"/>
                  </svg>
                {%- else -%}
                  <svg class="ds-star-rating__star ds-star-rating__star--empty" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.49L10 14.26 5.06 16.7 6 11.21l-4-3.9 5.53-.8L10 1.5z" class="ds-star-rating__star-bg"/>
                  </svg>
                {%- endif -%}
              {%- endfor -%}
            </span>
            <span class="ds-star-rating__count">({{ review_count_int }} {% if review_count_int == 1 %}review{% else %}reviews{% endif %})</span>
          </div>
        {%- endif -%}
      </header>

      <div class="ds-product__price-row">
        {% render 'price',
          price: current_variant.price,
          compare_at_price: current_variant.compare_at_price,
          size: 'lg'
        %}
      </div>

      {%- if product.description != blank -%}
        <div class="ds-product__description">
          <h2 class="ds-sr-only">Description</h2>
          <div class="ds-text ds-text--sm ds-text--muted">{{ product.description }}</div>
        </div>
      {%- endif -%}

      {%- if section.settings.show_sku and current_variant.sku != blank -%}
        <p class="ds-text ds-text--sm ds-product__sku">
          <span class="ds-sr-only">SKU:</span>
          SKU: {{ current_variant.sku }}
        </p>
      {%- endif -%}

      {% render 'product-form', product: product, section: section %}

      <div class="ds-product__actions">
        <p
          class="ds-text ds-text--sm ds-text--muted ds-stock-indicator ds-stock-indicator--{{ stock_status }}"
          aria-live="polite"
          data-stock-indicator
        >
          <span
            class="ds-stock-indicator__dot{% unless stock_status == 'out-of-stock' %} ds-stock-indicator__dot--pulse{% endunless %}"
            aria-hidden="true"
          ></span>
          {{ stock_label }}
        </p>

        <p class="ds-text ds-text--sm ds-text--muted ds-product__trust-signals">
          Free shipping over $50 · 30-day returns
        </p>
      </div>

      {%- if has_specs -%}
        <details class="ds-product__specs">
          <summary class="ds-product__specs-summary">
            <span class="ds-text ds-text--sm ds-text--medium">Specifications</span>
          </summary>
          <div class="ds-product__specs-body">
            <ul class="ds-product__specs-list">
              {%- for spec in specifications -%}
                <li class="ds-product__specs-item">
                  <span class="ds-text ds-text--sm ds-text--muted ds-product__specs-label">{{ spec.label | default: spec.name }}</span>
                  <span class="ds-text ds-text--sm ds-product__specs-value">{{ spec.value }}</span>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        </details>
      {%- endif -%}
    </div>
  </article>
</section>

{%- comment -%} ─── Gallery interactivity ─── {%- endcomment -%}
<script>
  (function () {
    var gallery = document.querySelector('[data-product-gallery]');
    if (!gallery) return;

    var slides = gallery.querySelectorAll('[data-gallery-slide]');
    var thumbs = gallery.querySelectorAll('[data-gallery-thumb]');
    if (slides.length === 0) return;

    function activate(index) {
      var clamped = Math.max(0, Math.min(slides.length - 1, index));
      for (var i = 0; i < slides.length; i++) {
        var isActive = i === clamped;
        slides[i].classList.toggle('ds-image-gallery__slide--active', isActive);
        if (isActive) {
          slides[i].removeAttribute('aria-hidden');
        } else {
          slides[i].setAttribute('aria-hidden', 'true');
        }
      }
      for (var j = 0; j < thumbs.length; j++) {
        var thumbActive = j === clamped;
        thumbs[j].classList.toggle('ds-image-gallery__thumb--active', thumbActive);
        thumbs[j].setAttribute('aria-selected', thumbActive ? 'true' : 'false');
        thumbs[j].setAttribute('tabindex', thumbActive ? '0' : '-1');
      }
    }

    for (var k = 0; k < thumbs.length; k++) {
      (function (idx) {
        thumbs[idx].addEventListener('click', function () { activate(idx); });
      })(k);
    }

    var thumbsList = gallery.querySelector('[role="tablist"]');
    if (thumbsList) {
      thumbsList.addEventListener('keydown', function (e) {
        var current = -1;
        for (var i = 0; i < thumbs.length; i++) {
          if (thumbs[i].getAttribute('aria-selected') === 'true') { current = i; break; }
        }
        if (current < 0) return;
        var next = null;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next = current + 1;
        else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') next = current - 1;
        else if (e.key === 'Home') next = 0;
        else if (e.key === 'End') next = thumbs.length - 1;
        if (next !== null) {
          e.preventDefault();
          next = Math.max(0, Math.min(thumbs.length - 1, next));
          activate(next);
          thumbs[next].focus();
        }
      });
    }
  })();
</script>

{%- comment -%} ─── JSON-LD Product schema ─── {%- endcomment -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | truncate: 5000 | json }},
    "image": [
      {%- for image in product.images -%}
        {{ image | image_url: width: 1200 | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ],
    {%- if product.vendor != blank -%}
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | json }}
    },
    {%- endif -%}
    {%- if current_variant.sku != blank -%}
    "sku": {{ current_variant.sku | json }},
    {%- endif -%}
    "url": {{ shop.url | append: product.url | json }},
    "offers": {
      "@type": "Offer",
      "price": {{ current_variant.price | money_without_currency | remove: ',' | json }},
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "availability": "{% if current_variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "url": {{ shop.url | append: product.url | json }},
      "itemCondition": "https://schema.org/NewCondition"
    }
    {%- if has_reviews -%}
    ,
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "{{ review_rating }}",
      "reviewCount": "{{ review_count }}"
    }
    {%- endif -%}
  }
</script>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "shopify-section-main-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sku",
      "label": "Show SKU",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_star_rating",
      "label": "Show star rating",
      "info": "Requires `reviews.rating` and `reviews.rating_count` product metafields.",
      "default": true
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "label": "Gallery layout",
      "options": [
        { "value": "stacked", "label": "Stacked" },
        { "value": "thumbnails-left", "label": "Thumbnails on left" },
        { "value": "thumbnails-bottom", "label": "Thumbnails below" }
      ],
      "default": "thumbnails-bottom"
    },
    {
      "type": "checkbox",
      "id": "enable_zoom",
      "label": "Enable image zoom affordance",
      "default": false
    }
  ],
  "presets": [{ "name": "Product" }]
}
{% endschema %}
