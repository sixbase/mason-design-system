{%- comment -%}
  Render a product card.

  Mirrors the ProductCard component in
  packages/components/src/product-card/ProductCard.tsx.
  Always rendered in the fluid variant — parent grid owns sizing.

  Accepts:
    product      Shopify product object, required
    loading      'lazy' | 'eager' (default 'lazy')
    sizes        CSS sizes attribute for responsive-image

  Usage:
    {% render 'product-card', product: product %}
{%- endcomment -%}

{%- liquid
  assign img_loading = loading | default: 'lazy'
  assign img_sizes = sizes | default: '(min-width: 1024px) 25vw, (min-width: 768px) 50vw, 100vw'
  assign primary_image = product.featured_image
  assign hover_image = nil
  if product.media.size > 1
    assign hover_image = product.media[1].preview_image
  endif

  assign is_on_sale = false
  if product.compare_at_price_max > product.price
    assign is_on_sale = true
  endif

  assign is_sold_out = false
  unless product.available
    assign is_sold_out = true
  endunless

  assign is_new = false
  if product.tags contains 'new'
    assign is_new = true
  endif
-%}

<div
  class="ds-card ds-card--ghost ds-card--interactive ds-product-card ds-product-card--fluid{% if hover_image %} ds-product-card--has-hover-image{% endif %}"
>
  <a
    href="{{ product.url }}"
    class="ds-product-card__link"
    aria-label="{{ product.title | escape }}"
  >
    <div class="ds-product-card__image-wrapper">
      <div class="ds-card-image">
        {%- if primary_image -%}
          <img
            src="{{ primary_image | image_url: width: 900 }}"
            srcset="
              {{ primary_image | image_url: width: 300 }} 300w,
              {{ primary_image | image_url: width: 600 }} 600w,
              {{ primary_image | image_url: width: 900 }} 900w,
              {{ primary_image | image_url: width: 1200 }} 1200w
            "
            sizes="{{ img_sizes }}"
            alt="{{ primary_image.alt | default: product.title | escape }}"
            width="{{ primary_image.width }}"
            height="{{ primary_image.height }}"
            loading="{{ img_loading }}"
            decoding="async"
            class="ds-card-image__img"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'ds-card-image__img' }}
        {%- endif -%}

        {%- if hover_image -%}
          <img
            src="{{ hover_image | image_url: width: 900 }}"
            srcset="
              {{ hover_image | image_url: width: 300 }} 300w,
              {{ hover_image | image_url: width: 600 }} 600w,
              {{ hover_image | image_url: width: 900 }} 900w,
              {{ hover_image | image_url: width: 1200 }} 1200w
            "
            sizes="{{ img_sizes }}"
            alt=""
            aria-hidden="true"
            loading="lazy"
            decoding="async"
            class="ds-card-image__img ds-product-card__hover-image"
          >
        {%- endif -%}
      </div>

      {%- if is_sold_out or is_on_sale or is_new -%}
        <div class="ds-product-card__badge">
          {%- if is_sold_out -%}
            <span class="ds-badge ds-badge--sm ds-badge--secondary">Sold out</span>
          {%- elsif is_on_sale -%}
            <span class="ds-badge ds-badge--sm ds-badge--destructive">Sale</span>
          {%- elsif is_new -%}
            <span class="ds-badge ds-badge--sm ds-badge--default">New</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="ds-card-body">
      <p class="ds-text ds-text--sm ds-product-card__name">{{ product.title | escape }}</p>

      {%- if is_on_sale -%}
        <div class="ds-product-card__price">
          {% render 'price',
            price: product.price,
            compare_at_price: product.compare_at_price,
            size: 'sm'
          %}
        </div>
      {%- else -%}
        <p class="ds-text ds-text--sm ds-text--muted ds-product-card__price">{{ product.price | money }}</p>
      {%- endif -%}
    </div>
  </a>
</div>

