{{ 'hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.heading
  assign body = section.settings.body
  assign cta_label = section.settings.cta_label
  assign cta_url = section.settings.cta_url
  assign image = section.settings.image
  assign overlay = section.settings.overlay_opacity
-%}

<div class="ds-page-container ds-section">
  <section class="ds-hero{% if image != blank %} ds-hero--has-image{% endif %}">
    {%- if image != blank -%}
      <div class="ds-hero__media">
        {% render 'responsive-image',
          image: image,
          alt: heading,
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high'
        %}
        {%- if overlay > 0 -%}
          <div class="ds-hero__overlay" data-overlay="{{ overlay }}"></div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="ds-hero__content">
      {%- if heading != blank -%}
        <h1 class="ds-heading ds-heading--4xl ds-hero__heading">{{ heading | escape }}</h1>
      {%- endif -%}

      {%- if body != blank -%}
        <p class="ds-text ds-text--lg ds-text--muted ds-hero__body">{{ body | escape }}</p>
      {%- endif -%}

      {%- if cta_label != blank and cta_url != blank -%}
        <a
          href="{{ cta_url }}"
          class="ds-button ds-button--primary ds-button--lg ds-hero__cta"
        >{{ cta_label | escape }}</a>
      {%- endif -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Everyday Essentials,\u00a0Thoughtfully Made" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Sustainably crafted goods designed to stand the test of time. Fewer things, made better." },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop the Collection" },
    { "type": "url", "id": "cta_url", "label": "Button link" },
    { "type": "image_picker", "id": "image", "label": "Background image (optional)" },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay strength",
      "min": 0, "max": 80, "step": 10, "default": 30,
      "info": "Darkens the image behind the text for readability."
    }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
