---
import '@ds/tokens/css';
import '@ds/components/styles';
import { Moon, Sun } from '@ds/components';
import './base.css';
import '../styles/demo-utilities.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Design system documentation' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Design System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Ancizar+Serif:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function(){
        var t=localStorage.getItem('ds-theme');
        if(t==='dark'||(!t&&matchMedia('(prefers-color-scheme:dark)').matches))
          document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body>
    <div class="layout">
      <aside class="sidebar">
        <nav>
          <div class="sidebar__header">
            <a href={`${base}/`} class="sidebar__logo">
              <img src={`${base}/mason-supply-co-logo.svg`} alt="Mason Supply Co." class="sidebar__logo-img" />
            </a>
            <button
              type="button"
              class="sidebar__theme-toggle"
              id="theme-toggle"
              aria-label="Toggle dark mode"
            >
              <Sun size="sm" className="sidebar__theme-icon sidebar__theme-icon--sun" />
              <Moon size="sm" className="sidebar__theme-icon sidebar__theme-icon--moon" />
            </button>
          </div>

          <div class="sidebar__section">
            <p class="sidebar__section-label">Getting Started</p>
            <a href={`${base}/`} class="sidebar__link">Introduction</a>
            <a href={`${base}/getting-started`} class="sidebar__link">Installation</a>
          </div>

          <div class="sidebar__section">
            <p class="sidebar__section-label">Foundation</p>
            <a href={`${base}/tokens/colors`} class="sidebar__link">Colors</a>
            <a href={`${base}/tokens/typography`} class="sidebar__link">Typography</a>
            <a href={`${base}/tokens/spacing`} class="sidebar__link">Spacing</a>
            <a href={`${base}/tokens/layout`} class="sidebar__link">Layout</a>
          </div>

          <div class="sidebar__section">
            <p class="sidebar__section-label">Components</p>
            <a href={`${base}/components/accordion`} class="sidebar__link">Accordion</a>
            <a href={`${base}/components/add-to-cart-button`} class="sidebar__link">Add to Cart Button</a>
            <a href={`${base}/components/alert`} class="sidebar__link">Alert</a>
            <a href={`${base}/components/announcement-bar`} class="sidebar__link">Announcement Bar</a>
            <a href={`${base}/components/badge`} class="sidebar__link">Badge</a>
            <a href={`${base}/components/breadcrumb`} class="sidebar__link">Breadcrumb</a>
            <a href={`${base}/components/button`} class="sidebar__link">Button</a>
            <a href={`${base}/components/card`} class="sidebar__link">Card</a>
            <a href={`${base}/components/cart-drawer`} class="sidebar__link">Cart Drawer</a>
            <a href={`${base}/components/cart-line-item`} class="sidebar__link">Cart Line Item</a>
            <a href={`${base}/components/carousel`} class="sidebar__link">Carousel</a>
            <a href={`${base}/components/checkbox`} class="sidebar__link">Checkbox</a>
            <a href={`${base}/components/collection-filters`} class="sidebar__link">Collection Filters</a>
            <a href={`${base}/components/color-picker`} class="sidebar__link">Color Picker</a>
            <a href={`${base}/components/cookie-consent`} class="sidebar__link">Cookie Consent</a>
            <a href={`${base}/components/divider`} class="sidebar__link">Divider</a>
            <a href={`${base}/components/drawer`} class="sidebar__link">Drawer</a>
            <a href={`${base}/components/empty-state`} class="sidebar__link">Empty State</a>
            <a href={`${base}/components/feature-block`} class="sidebar__link">Feature Block</a>
            <a href={`${base}/components/footer`} class="sidebar__link">Footer</a>
            <a href={`${base}/components/header`} class="sidebar__link">Header</a>
            <a href={`${base}/components/icon`} class="sidebar__link">Icon</a>
            <a href={`${base}/components/image-gallery`} class="sidebar__link">Image Gallery</a>
            <a href={`${base}/components/input`} class="sidebar__link">Input</a>
            <a href={`${base}/components/modal`} class="sidebar__link">Modal</a>
            <a href={`${base}/components/pagination`} class="sidebar__link">Pagination</a>
            <a href={`${base}/components/predictive-search`} class="sidebar__link">Predictive Search</a>
            <a href={`${base}/components/price-display`} class="sidebar__link">Price Display</a>
            <a href={`${base}/components/progress-bar`} class="sidebar__link">Progress Bar</a>
            <a href={`${base}/components/product-card`} class="sidebar__link">Product Card</a>
            <a href={`${base}/components/quantity-selector`} class="sidebar__link">Quantity Selector</a>
            <a href={`${base}/components/select`} class="sidebar__link">Select</a>
            <a href={`${base}/components/skeleton`} class="sidebar__link">Skeleton</a>
            <a href={`${base}/components/star-rating`} class="sidebar__link">Star Rating</a>
            <a href={`${base}/components/stock-indicator`} class="sidebar__link">Stock Indicator</a>
            <a href={`${base}/components/table`} class="sidebar__link">Table</a>
            <a href={`${base}/components/tabs`} class="sidebar__link">Tabs</a>
            <a href={`${base}/components/toast`} class="sidebar__link">Toast</a>
            <a href={`${base}/components/variant-selector`} class="sidebar__link">Variant Selector</a>
            <a href={`${base}/components/typography`} class="sidebar__link">Typography</a>
          </div>

          <div class="sidebar__section">
            <p class="sidebar__section-label">Examples</p>
            <a href={`${base}/examples/homepage`} class="sidebar__link">Homepage</a>
            <a href={`${base}/examples/collection`} class="sidebar__link">Collection</a>
            <a href={`${base}/examples/product-detail`} class="sidebar__link">Product Detail Page</a>
            <a href={`${base}/examples/cart`} class="sidebar__link">Cart</a>
            <a href={`${base}/examples/search`} class="sidebar__link">Search Results</a>
            <a href={`${base}/examples/account`} class="sidebar__link">Account</a>
            <a href={`${base}/examples/terms`} class="sidebar__link">Terms &amp; Conditions</a>
            <a href={`${base}/examples/sale`} class="sidebar__link">Sale</a>
          </div>
        </nav>
      </aside>

      <main class="content">
        <slot />
      </main>
    </div>
    <script is:inline>
      document.getElementById('theme-toggle').addEventListener('click', function() {
        var isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('ds-theme', isDark ? 'dark' : 'light');
      });
    </script>
  </body>
</html>
