{{ 'featured-collection.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}
{{ 'carousel.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign heading = section.settings.heading
  assign body = section.settings.body
  assign limit = section.settings.products_to_show | default: 6
  assign layout = section.settings.layout | default: 'carousel'
  assign columns = section.settings.columns_desktop | default: 4
  assign show_view_all = section.settings.show_view_all
-%}

<section class="ds-featured-collection ds-section">
  <div class="ds-page-container">
    {%- if heading != blank or body != blank -%}
      <header class="ds-featured-collection__header">
        {%- if heading != blank -%}
          <h2 class="ds-heading ds-heading--2xl">{{ heading | escape }}</h2>
        {%- endif -%}
        {%- if body != blank -%}
          <p class="ds-text ds-text--sm ds-text--muted">{{ body | escape }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if collection and collection.products.size > 0 -%}
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "ItemList",
          "name": {{ heading | default: collection.title | json }},
          "itemListElement": [
            {%- for product in collection.products limit: limit -%}
              {
                "@type": "ListItem",
                "position": {{ forloop.index }},
                "url": {{ shop.url | append: product.url | json }},
                "name": {{ product.title | json }}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ]
        }
      </script>

      {%- if layout == 'carousel' -%}
        <div class="ds-carousel ds-carousel--gap-md">
          <div class="ds-carousel__track ds-scroll-hidden">
            {%- for product in collection.products limit: limit -%}
              <div class="ds-carousel__slide ds-carousel__slide--sm">
                {% render 'product-card', product: product %}
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- else -%}
        <ul
          class="ds-featured-collection__grid"
          data-columns="{{ columns }}"
          role="list"
        >
          {%- for product in collection.products limit: limit -%}
            <li>{% render 'product-card', product: product %}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if show_view_all -%}
        <div class="ds-featured-collection__view-all">
          <a
            href="{{ collection.url }}"
            class="ds-button ds-button--secondary ds-button--md"
          >View all {{ collection.title | escape }}</a>
        </div>
      {%- endif -%}
    {%- else -%}
      <p class="ds-text ds-text--sm ds-text--muted">Select a collection in the theme editor to display products here.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Products" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Our most-loved pieces, curated for you." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "carousel", "label": "Carousel" },
        { "value": "grid", "label": "Grid" }
      ],
      "default": "carousel"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2, "max": 12, "step": 1, "default": 6
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Grid columns on desktop",
      "min": 2, "max": 4, "step": 1, "default": 4,
      "info": "Only applies when Layout = Grid."
    },
    { "type": "checkbox", "id": "show_view_all", "label": "Show \"View all\" button", "default": true }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
