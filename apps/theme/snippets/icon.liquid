{%- comment -%}
  Render an SVG icon.

  Mirrors the Icon component in packages/components/src/icon/Icon.tsx.
  Outputs a <svg class="ds-icon ds-icon--{size}"> with the matching path data.

  Accepts:
    name          string, required — one of: cart, search, account, close,
                  menu, chevron-down, chevron-right, chevron-left, heart,
                  check, plus, minus
    size          'sm' | 'md' | 'lg' (default 'md')
    aria_label    string — used when decorative is false
    decorative    boolean — default true; when true, aria-hidden is set

  Usage:
    {% render 'icon', name: 'cart' %}
    {% render 'icon', name: 'search', size: 'lg' %}
    {% render 'icon', name: 'close', decorative: false, aria_label: 'Close' %}
{%- endcomment -%}

{%- liquid
  assign icon_size = size | default: 'md'
  assign is_decorative = decorative
  if is_decorative == nil
    assign is_decorative = true
  endif
-%}

<svg
  class="ds-icon ds-icon--{{ icon_size }}"
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  {% if is_decorative %}aria-hidden="true"{% else %}role="img" aria-label="{{ aria_label | escape }}"{% endif %}
>
  {%- case name -%}
    {%- when 'cart' -%}
      <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
    {%- when 'search' -%}
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    {%- when 'account' -%}
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
    {%- when 'close' -%}
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    {%- when 'menu' -%}
      <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
    {%- when 'chevron-down' -%}
      <polyline points="6 9 12 15 18 9"/>
    {%- when 'chevron-right' -%}
      <polyline points="9 18 15 12 9 6"/>
    {%- when 'chevron-left' -%}
      <polyline points="15 18 9 12 15 6"/>
    {%- when 'heart' -%}
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
    {%- when 'check' -%}
      <polyline points="20 6 9 17 4 12"/>
    {%- when 'plus' -%}
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    {%- when 'minus' -%}
      <line x1="5" y1="12" x2="19" y2="12"/>
  {%- endcase -%}
</svg>
