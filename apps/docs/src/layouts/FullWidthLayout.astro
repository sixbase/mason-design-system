---
import '@ds/tokens/css';
import '@ds/components/styles';
import './base.css';
import '../styles/demo-utilities.css';
import { Header } from '@ds/components';
import { Footer } from '@ds/components';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Design system documentation' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const NAV_ITEMS = [
  { label: 'Shop', href: `${base}/examples/homepage` },
  { label: 'Collections', href: `${base}/examples/collection` },
  { label: 'About', href: '#' },
];

const FOOTER_COLUMNS = [
  {
    heading: 'Shop',
    links: [
      { label: 'Phone Cases', href: '#' },
      { label: 'Wallets', href: '#' },
      { label: 'Bags', href: '#' },
      { label: 'Accessories', href: '#' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { label: 'About', href: '#' },
      { label: 'Journal', href: '#' },
      { label: 'Sustainability', href: '#' },
      { label: 'Careers', href: '#' },
    ],
  },
  {
    heading: 'Support',
    links: [
      { label: 'Contact', href: '#' },
      { label: 'Shipping & Returns', href: '#' },
      { label: 'FAQ', href: '#' },
      { label: 'Warranty', href: '#' },
    ],
  },
];

const LEGAL_LINKS = [
  { label: 'Privacy Policy', href: '#' },
  { label: 'Terms of Service', href: '#' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Design System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,200..900;1,8..60,200..900&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function(){
        var t=localStorage.getItem('ds-theme');
        if(t==='dark'||(!t&&matchMedia('(prefers-color-scheme:dark)').matches))
          document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body>
    <Header
      client:load
      logoSrc={`${base}/mason-supply-co-logo.svg`}
      logoAlt="Mason Supply Co."
      logoHref={`${base}/`}
      navItems={NAV_ITEMS}
      cartHref={`${base}/examples/cart`}
      cartCount={0}
    />
    <main class="ds-page-container">
      <slot />
    </main>
    <Footer
      client:load
      logoSrc={`${base}/mason-supply-co-logo.svg`}
      logoAlt="Mason Supply Co."
      logoHref={`${base}/`}
      tagline="Thoughtfully designed accessories for everyday carry."
      columns={FOOTER_COLUMNS}
      copyright="&copy; 2026 Mason Supply Co. All rights reserved."
      legalLinks={LEGAL_LINKS}
    />
  </body>
</html>

<style>
  /* ─── Main ────────────────────────────────────────────── */
  /* Layout handled by .ds-page-container from layout-grid.css.
     Only vertical padding added here (inline padding is in the grid system). */
  main {
    padding-block: var(--spacing-4);
  }

  @media (min-width: 768px) {
    main {
      padding-block: var(--spacing-6);
    }
  }
</style>
