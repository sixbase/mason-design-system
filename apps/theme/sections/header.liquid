{{ 'header.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign logo_alt = section.settings.logo_alt
  if logo_alt == blank
    assign logo_alt = shop.name
  endif

  assign menu_handle = section.settings.menu
  assign menu = linklists[menu_handle]
  assign cart_count = cart.item_count
-%}

<a class="ds-header__skip-link" href="#MainContent">Skip to content</a>

<header class="ds-header" role="banner">
  <div class="ds-header__inner">
    <a
      href="{{ routes.root_url }}"
      class="ds-header__logo"
      aria-label="{{ logo_alt | escape }}"
    >
      {%- if section.settings.logo != blank -%}
        {%- assign logo_width = section.settings.logo.width | at_most: 360 -%}
        <img
          src="{{ section.settings.logo | image_url: width: logo_width }}"
          srcset="
            {{ section.settings.logo | image_url: width: 120 }} 120w,
            {{ section.settings.logo | image_url: width: 240 }} 240w,
            {{ section.settings.logo | image_url: width: 360 }} 360w
          "
          sizes="(max-width: 768px) 120px, 180px"
          alt="{{ logo_alt | escape }}"
          class="ds-header__logo-img"
          width="{{ section.settings.logo.width }}"
          height="{{ section.settings.logo.height }}"
          loading="eager"
        >
      {%- else -%}
        {%- comment -%} Default: brand wordmark SVG shipped with the theme {%- endcomment -%}
        <img
          src="{{ 'mason-supply-co-logo.svg' | asset_url }}"
          alt="{{ logo_alt | escape }}"
          class="ds-header__logo-img"
          width="180"
          height="24"
          loading="eager"
        >
      {%- endif -%}
    </a>

    {%- if menu != blank and menu.links.size > 0 -%}
      <nav class="ds-header__nav" aria-label="Main">
        {%- for link in menu.links -%}
          <a
            href="{{ link.url }}"
            {% if link.active %}aria-current="page"{% endif %}
          >{{ link.title }}</a>
        {%- endfor -%}
      </nav>
    {%- else -%}
      {%- comment -%}
        Fallback nav when the merchant hasn't configured the main-menu
        linklist. Mirrors the docs FullWidthLayout defaults.
      {%- endcomment -%}
      {%- assign fallback_path = request.path -%}
      <nav class="ds-header__nav" aria-label="Main">
        <a href="{{ routes.all_products_collection_url }}"{% if fallback_path contains '/collections/all' %} aria-current="page"{% endif %}>Shop</a>
        <a href="{{ routes.collections_url }}"{% if fallback_path == routes.collections_url %} aria-current="page"{% endif %}>Collections</a>
        <a href="{{ routes.root_url }}pages/about"{% if fallback_path contains '/pages/about' %} aria-current="page"{% endif %}>About</a>
      </nav>
    {%- endif -%}

    <div class="ds-header__actions">
      {%- if section.settings.show_search -%}
        <a
          href="{{ routes.search_url }}"
          class="ds-header__icon-btn ds-header__search"
          aria-label="Search"
        >
          {% render 'icon', name: 'search' %}
        </a>
      {%- endif -%}

      {%- if section.settings.show_theme_toggle -%}
        <button
          type="button"
          class="ds-header__icon-btn ds-header__theme-toggle"
          aria-label="Toggle dark mode"
          aria-pressed="false"
          data-theme-toggle
        >
          {% render 'icon', name: 'sun', extra_class: 'ds-header__theme-icon--sun' %}
          {% render 'icon', name: 'moon', extra_class: 'ds-header__theme-icon--moon' %}
        </button>
      {%- endif -%}

      <a
        href="{{ routes.cart_url }}"
        class="ds-header__icon-btn ds-header__cart"
        aria-label="Shopping bag ({{ cart_count }} {% if cart_count == 1 %}item{% else %}items{% endif %})"
      >
        {% render 'icon', name: 'cart' %}
        {%- if cart_count > 0 -%}
          <span class="ds-badge ds-badge--sm ds-badge--default ds-header__cart-count" aria-hidden="true">
            {{- cart_count -}}
          </span>
        {%- endif -%}
      </a>
    </div>
  </div>
</header>

<script>
  (function () {
    var root = document.documentElement;
    var toggle = document.querySelector('[data-theme-toggle]');
    if (!toggle) return;

    /* Initial class restoration is handled by the inline <head> script
       in theme.liquid — this handler only flips the class on click. */
    /* Reflect current .dark state in aria-pressed on first load. */
    toggle.setAttribute('aria-pressed', root.classList.contains('dark') ? 'true' : 'false');

    toggle.addEventListener('click', function () {
      var next = !root.classList.contains('dark');
      root.classList.toggle('dark', next);
      toggle.setAttribute('aria-pressed', next ? 'true' : 'false');
      try {
        localStorage.setItem('ds-theme', next ? 'dark' : 'light');
      } catch (e) {}
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo alt text",
      "default": "Mason Supply Co.",
      "info": "Defaults to the store name if left blank."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search link",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_theme_toggle",
      "label": "Show dark/light theme toggle",
      "default": true
    }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
