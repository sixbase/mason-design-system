{%- comment -%}
  Product lifestyle — "In the Wild" carousel below the PDP fold.

  Mirrors the Carousel section in the DS PDPDemo. Pure CSS scroll-snap
  (no JS) — touch + mouse drag work natively.

  Image source priority:
    1. product.metafields.custom.lifestyle_images.value (preferred —
       merchant-curated environmental shots distinct from gallery)
    2. product.images sliced past the featured image (fallback so the
       section ships something on stores that haven't populated the
       metafield yet).
    3. Otherwise the section silently skips.
{%- endcomment -%}

{{ 'carousel.css' | asset_url | stylesheet_tag }}
{{ 'product-lifestyle.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.heading | default: 'In the wild'
  assign subtitle = section.settings.subtitle

  comment
    Image source priority — nil-safe via the `blank` keyword, which
    matches nil, empty arrays, empty strings, and false (unlike
    `empty`, which only matches the EmptyDrop sentinel).

    `offset` is an array-iteration filter that doesn't work on
    `product.images` (Shopify's MediaCollectionDrop) outside of a
    `for` loop, so we keep the full list and let the `for` tag's
    own `offset:` parameter skip the featured image when we fall
    back to the gallery.
  endcomment
  assign images_to_show = product.metafields.custom.lifestyle_images.value
  assign use_gallery_fallback = false

  if images_to_show == blank
    if product.images.size > 1
      assign images_to_show = product.images
      assign use_gallery_fallback = true
    endif
  endif

  assign has_images = false
  if images_to_show != blank and images_to_show.size > 0
    assign has_images = true
  endif

  assign visible_count = images_to_show.size
  if use_gallery_fallback
    assign visible_count = visible_count | minus: 1
  endif
-%}

{%- if has_images -%}
  <section
    class="ds-section ds-page-container ds-product-lifestyle"
    aria-labelledby="product-lifestyle-heading-{{ section.id }}"
  >
    <header class="ds-product-lifestyle__header">
      <h2
        id="product-lifestyle-heading-{{ section.id }}"
        class="ds-heading ds-heading--3xl"
      >
        {{- heading | escape -}}
      </h2>
      {%- if subtitle != blank -%}
        <p class="ds-text ds-text--base ds-text--muted">
          {{- subtitle | escape -}}
        </p>
      {%- endif -%}
    </header>

    <div class="ds-carousel ds-carousel--gap-md" aria-roledescription="carousel">
      <div class="ds-carousel__track ds-scroll-hidden" role="group" aria-label="{{ heading | escape }} images">
        {%- if use_gallery_fallback -%}
          {%- for image in images_to_show offset: 1 -%}
            <div
              class="ds-carousel__slide ds-carousel__slide--md"
              role="group"
              aria-roledescription="slide"
              aria-label="{{ forloop.index }} of {{ visible_count }}"
            >
              {% render 'responsive-image',
                image: image,
                alt: image.alt | default: product.title,
                sizes: '(min-width: 1024px) 50vw, 85vw',
                class: 'ds-product-lifestyle__img'
              %}
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for image in images_to_show -%}
            <div
              class="ds-carousel__slide ds-carousel__slide--md"
              role="group"
              aria-roledescription="slide"
              aria-label="{{ forloop.index }} of {{ visible_count }}"
            >
              {% render 'responsive-image',
                image: image,
                alt: image.alt | default: product.title,
                sizes: '(min-width: 1024px) 50vw, 85vw',
                class: 'ds-product-lifestyle__img'
              %}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Product lifestyle",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "In the wild"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "See it in action"
    }
  ],
  "presets": [{ "name": "Product lifestyle" }]
}
{% endschema %}
