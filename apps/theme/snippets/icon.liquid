{%- comment -%}
  Render an SVG icon.

  Mirrors the Icon component in packages/components/src/icon/Icon.tsx.
  Outputs a <svg class="ds-icon ds-icon--{size}"> with the matching path data.

  Accepts:
    name          string, required — one of: cart, search, account, close,
                  menu, chevron-down, chevron-right, chevron-left, heart,
                  check, plus, minus
    size          'sm' | 'md' | 'lg' (default 'md')
    aria_label    string — used when decorative is false
    decorative    boolean — default true; when true, aria-hidden is set

  Usage:
    {% render 'icon', name: 'cart' %}
    {% render 'icon', name: 'search', size: 'lg' %}
    {% render 'icon', name: 'close', decorative: false, aria_label: 'Close' %}
{%- endcomment -%}

{%- liquid
  assign icon_size = size | default: 'md'
  assign is_decorative = decorative
  if is_decorative == nil
    assign is_decorative = true
  endif
-%}

<svg
  class="ds-icon ds-icon--{{ icon_size }}"
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  {% if is_decorative %}aria-hidden="true"{% else %}role="img" aria-label="{{ aria_label | escape }}"{% endif %}
>
  {%- case name -%}
    {%- when 'cart' -%}
      <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
    {%- when 'search' -%}
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    {%- when 'account' -%}
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
    {%- when 'close' -%}
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    {%- when 'menu' -%}
      <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
    {%- when 'chevron-down' -%}
      <polyline points="6 9 12 15 18 9"/>
    {%- when 'chevron-right' -%}
      <polyline points="9 18 15 12 9 6"/>
    {%- when 'chevron-left' -%}
      <polyline points="15 18 9 12 15 6"/>
    {%- when 'heart' -%}
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
    {%- when 'check' -%}
      <polyline points="20 6 9 17 4 12"/>
    {%- when 'plus' -%}
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    {%- when 'minus' -%}
      <line x1="5" y1="12" x2="19" y2="12"/>
    {%- when 'instagram' -%}
      <rect x="3" y="3" width="18" height="18" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
    {%- when 'twitter' -%}
      <path d="M22 4.01c-1 .49-1.98.689-3 .99-1.121-1.265-2.783-1.335-4.38-.737S11.977 6.323 12 8v1c-3.245.083-6.135-1.395-8-4 0 0-4.182 7.433 4 11-1.872 1.247-3.739 2.088-6 2 3.308 1.803 6.913 2.423 10.034 1.517 3.58-1.04 6.522-3.723 7.651-7.742a13.84 13.84 0 0 0 .497-3.753c0-.249 1.51-2.772 1.818-4.013z"/>
    {%- when 'facebook' -%}
      <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
    {%- when 'youtube' -%}
      <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
    {%- when 'tiktok' -%}
      <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/><path d="M15 3c0 2.5 2 4.5 4.5 4.5"/>
  {%- endcase -%}
</svg>
