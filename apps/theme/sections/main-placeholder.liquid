<section class="ds-page-container ds-section">
  <h1 class="ds-heading ds-heading--2xl">
    {{ section.settings.heading | default: 'Design System Theme' }}
  </h1>
  <p class="ds-text ds-text--base ds-text--muted">
    {{ section.settings.body | default: 'This theme consumes @ds/tokens. Sections will be built on top of the design system.' }}
  </p>
</section>

{% schema %}
{
  "name": "Placeholder",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Design System Theme"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "This theme consumes @ds/tokens."
    }
  ],
  "presets": [
    {
      "name": "Placeholder"
    }
  ]
}
{% endschema %}
