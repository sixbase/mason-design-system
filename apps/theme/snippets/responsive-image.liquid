{%- comment -%}
  Render a responsive image with srcset + sizes.

  Consumes Shopify's image CDN via the `image_url` filter to generate
  multiple widths. Produces descriptive alt (falls back to image.alt)
  and the correct `loading` attribute per above/below the fold.

  Accepts:
    image         Shopify image object, required
    alt           string — overrides image.alt if provided
    sizes         CSS sizes attribute, default '(min-width: 1024px) 50vw, 100vw'
    loading       'lazy' | 'eager' (default 'lazy')
    fetchpriority 'high' | 'low' | 'auto' (default 'auto')
    class         additional CSS class
    focal_point   image.presentation.focal_point hash {x, y} (0–1 fractions).
                  Emitted as inline `object-position` so cover-cropped images
                  keep the merchant-set focal area in view. Pair with
                  `object-fit: cover` on the img.

  Usage:
    {% render 'responsive-image', image: product.featured_image, alt: product.title %}
    {% render 'responsive-image', image: image, focal_point: image.presentation.focal_point %}
{%- endcomment -%}

{%- liquid
  assign img_alt = alt | default: image.alt | default: ''
  assign img_sizes = sizes | default: '(min-width: 1024px) 50vw, 100vw'
  assign img_loading = loading | default: 'lazy'
  assign img_priority = fetchpriority | default: 'auto'
  assign img_class = class | default: ''
  assign widths = '300,600,900,1200,1500,1800,2400'

  assign focal_style = ''
  if focal_point and focal_point.x and focal_point.y
    assign fx = focal_point.x | times: 100
    assign fy = focal_point.y | times: 100
    assign focal_style = 'object-position: ' | append: fx | append: '% ' | append: fy | append: '%;'
  endif
-%}

{%- if image -%}
  <img
    src="{{ image | image_url: width: 1200 }}"
    srcset="
      {%- assign widths_arr = widths | split: ',' -%}
      {%- for w in widths_arr -%}
        {{ image | image_url: width: w }} {{ w }}w{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    "
    sizes="{{ img_sizes }}"
    alt="{{ img_alt | escape }}"
    width="{{ image.width }}"
    height="{{ image.height }}"
    loading="{{ img_loading }}"
    fetchpriority="{{ img_priority }}"
    decoding="async"
    {% if img_class != '' %}class="{{ img_class }}"{% endif %}
    {% if focal_style != '' %}style="{{ focal_style }}"{% endif %}
  >
{%- endif -%}
