{{ 'feature-block.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign title = section.settings.title
  assign description = section.settings.description
  assign image = section.settings.image
  assign reverse = section.settings.reverse
  assign cta_label = section.settings.cta_label
  assign cta_url = section.settings.cta_url
  assign placeholder = section.settings.placeholder
  assign block_class = 'ds-feature-block'
  if reverse
    assign block_class = block_class | append: ' ds-feature-block--reverse'
  endif
-%}

<section class="ds-section ds-feature-block-section">
  <div class="ds-page-container">
    <div class="{{ block_class }}">
      <div class="ds-feature-block__image">
        {%- if image != blank -%}
          {% render 'responsive-image',
            image: image,
            alt: title,
            sizes: '(min-width: 768px) 50vw, 100vw'
          %}
        {%- elsif placeholder != blank and placeholder != 'none' -%}
          {%- assign placeholder_src = 'feature-' | append: placeholder | append: '.svg' | asset_url -%}
          <img
            src="{{ placeholder_src }}"
            alt="{{ title | escape }}"
            class="ds-feature-block__placeholder"
            width="1000"
            height="800"
            loading="lazy"
          >
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'ds-feature-block__placeholder' }}
        {%- endif -%}
      </div>

      <div class="ds-feature-block__text">
        {%- if title != blank -%}
          <h2 class="ds-heading ds-heading--xl ds-heading--normal ds-feature-block__title">{{ title | escape }}</h2>
        {%- endif -%}

        {%- if description != blank -%}
          <p class="ds-text ds-text--base ds-text--muted">{{ description | escape }}</p>
        {%- endif -%}

        {%- if cta_label != blank and cta_url != blank -%}
          <a
            href="{{ cta_url }}"
            class="ds-button ds-button--secondary ds-button--md"
          >{{ cta_label | escape }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature block",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Our craft" },
    { "type": "textarea", "id": "description", "label": "Description" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select",
      "id": "placeholder",
      "label": "Fallback placeholder (when no image is set)",
      "options": [
        { "value": "none", "label": "Shopify default (lifestyle-1)" },
        { "value": "materials", "label": "Materials — warm stone" },
        { "value": "durability", "label": "Durability — muted stone" },
        { "value": "zero-waste", "label": "Zero Waste — deep stone" }
      ],
      "default": "materials"
    },
    { "type": "text", "id": "cta_label", "label": "Button label" },
    { "type": "url", "id": "cta_url", "label": "Button link" },
    { "type": "checkbox", "id": "reverse", "label": "Swap image and text positions", "default": false }
  ],
  "presets": [{ "name": "Feature block" }]
}
{% endschema %}
