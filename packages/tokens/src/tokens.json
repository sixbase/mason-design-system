{
  "$schema": "./tokens.schema.json",
  "primitive": {
    "color": {
      "stone": {
        "0":   "#FFFFFF",
        "50":  "#FAF9F7",
        "100": "#F2F0EB",
        "200": "#E3DED6",
        "300": "#C8C2B8",
        "400": "#A59E94",
        "500": "#847D73",
        "600": "#675F56",
        "700": "#4E473F",
        "800": "#342F2A",
        "900": "#1F1C18",
        "950": "#131010"
      },
      "brick": {
        "50":  "#FDF0ED",
        "100": "#FAE0D8",
        "400": "#E07060",
        "500": "#C45040",
        "600": "#A03830",
        "700": "#7D2A24"
      },
      "sage": {
        "50":  "#F2F7F0",
        "100": "#E0EDD9",
        "400": "#82B074",
        "500": "#5E8F50",
        "600": "#4A7040",
        "700": "#375530"
      },
      "amber": {
        "50":  "#FBF5E6",
        "100": "#F5E7C0",
        "400": "#D4A040",
        "500": "#B8853A",
        "600": "#9A6B28",
        "700": "#7A5020"
      },
      "slate": {
        "50":  "#EFF2F8",
        "100": "#DDE4F0",
        "400": "#7A90B8",
        "500": "#607AA8",
        "600": "#4A5F8A",
        "700": "#374870"
      }
    },
    "spacing": {
      "0":   "0px",
      "1":   "4px",
      "2":   "8px",
      "3":   "12px",
      "4":   "16px",
      "5":   "20px",
      "6":   "24px",
      "8":   "32px",
      "10":  "40px",
      "12":  "48px",
      "16":  "64px",
      "20":  "80px",
      "24":  "96px",
      "phi-1":  "2px",
      "phi-2":  "4px",
      "phi-3":  "6px",
      "phi-5":  "10px",
      "phi-8":  "16px",
      "phi-13": "26px",
      "phi-21": "42px",
      "phi-34": "68px",
      "phi-55": "110px",
      "phi-89": "178px"
    },
    "size": {
      "control-sm":  "34px",
      "control-md":  "42px",
      "control-lg":  "55px",
      "checkbox-sm": "13px",
      "checkbox-md": "21px",
      "icon":        "16px",
      "icon-sm":     "16px",
      "icon-md":     "20px",
      "icon-lg":     "24px",
      "content-sm":  "640px",
      "content-md":  "768px",
      "content-lg":  "960px",
      "content-xl":  "1280px",
      "container-max": "1200px",
      "touch-target": "36px",
      "touch-target-lg": "44px",
      "modal-sm":    "400px",
      "modal-md":    "520px",
      "modal-lg":    "680px"
    },
    "radius": {
      "none": "0px",
      "xs":   "1px",
      "sm":   "2px",
      "md":   "5px",
      "lg":   "8px",
      "xl":   "13px",
      "2xl":  "21px",
      "full": "9999px"
    },
    "borderWidth": {
      "sm": "1px",
      "md": "1.5px",
      "lg": "2px",
      "xl": "3px"
    },
    "font": {
      "family": {
        "body": "'Ancizar Serif', ui-serif, Georgia, serif",
        "code": "'JetBrains Mono', ui-monospace, 'Cascadia Code', monospace"
      },
      "size": {
        "xs":   "0.75rem",
        "sm":   "0.875rem",
        "base": "clamp(0.9375rem, 0.91rem + 0.19vw, 1rem)",
        "lg":   "clamp(1.0625rem, 0.94rem + 0.56vw, 1.25rem)",
        "xl":   "clamp(1.25rem, 1.03rem + 1.13vw, 1.625rem)",
        "2xl":  "clamp(1.5rem, 1.17rem + 1.69vw, 2.0625rem)",
        "3xl":  "clamp(1.75rem, 1.24rem + 2.63vw, 2.625rem)",
        "4xl":  "clamp(2.125rem, 1.39rem + 3.76vw, 3.375rem)",
        "5xl":  "clamp(2.5rem, 1.47rem + 5.26vw, 4.25rem)",
        "tight-2xs":  "0.625rem",
        "tight-xs":   "0.75rem",
        "tight-sm":   "0.875rem",
        "tight-base": "1rem",
        "tight-lg":   "1.1875rem",
        "tight-xl":   "1.375rem",
        "tight-2xl":  "1.625rem",
        "tight-3xl":  "1.875rem",
        "tight-4xl":  "2.25rem",
        "display-xs":  "0.625rem",
        "display-sm":  "1rem",
        "display-md":  "1.625rem",
        "display-lg":  "2.625rem",
        "display-xl":  "4.25rem",
        "display-2xl": "6.875rem"
      },
      "weight": {
        "light":    "300",
        "normal":   "400",
        "medium":   "500",
        "semibold": "600",
        "bold":     "700"
      },
      "lineHeight": {
        "none":    "1",
        "tight":   "1.15",
        "snug":    "1.382",
        "normal":  "1.5",
        "relaxed": "1.618",
        "loose":   "2"
      },
      "letterSpacing": {
        "tighter": "-0.05em",
        "tight":   "-0.025em",
        "normal":  "0em",
        "wide":    "0.025em",
        "wider":   "0.05em"
      }
    },
    "shadow": {
      "sm":  "0 1px 2px 0 rgb(0 0 0 / 0.05)",
      "md":  "0 2px 5px -1px rgb(0 0 0 / 0.08), 0 1px 3px -1px rgb(0 0 0 / 0.05)",
      "lg":  "0 5px 13px -3px rgb(0 0 0 / 0.08), 0 2px 5px -2px rgb(0 0 0 / 0.06)",
      "xl":  "0 8px 21px -5px rgb(0 0 0 / 0.1), 0 3px 8px -3px rgb(0 0 0 / 0.08)",
      "2xl": "0 13px 34px -8px rgb(0 0 0 / 0.18), 0 5px 13px -5px rgb(0 0 0 / 0.12)",
      "none": "none"
    },
    "transition": {
      "duration": {
        "fast":   "100ms",
        "normal": "162ms",
        "slow":   "262ms"
      },
      "easing": {
        "default":    "cubic-bezier(0.4, 0, 0.2, 1)",
        "in":         "cubic-bezier(0.4, 0, 1, 1)",
        "out":        "cubic-bezier(0, 0, 0.2, 1)",
        "in-out":     "cubic-bezier(0.4, 0, 0.2, 1)"
      }
    },
    "opacity": {
      "full":   "1",
      "high":   "0.618",
      "medium": "0.382",
      "low":    "0.236",
      "subtle": "0.146",
      "ghost":  "0.09"
    },
    "zIndex": {
      "base":    "0",
      "raised":  "10",
      "sticky":  "50",
      "overlay": "100",
      "modal":   "200",
      "toast":   "300",
      "tooltip": "400"
    },
    "breakpoint": {
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px"
    }
  },
  "semantic": {
    "color": {
      "background":           { "$value": "{primitive.color.stone.50}" },
      "background-subtle":    { "$value": "{primitive.color.stone.100}" },
      "background-surface":   { "$value": "{primitive.color.stone.0}" },
      "foreground":           { "$value": "{primitive.color.stone.950}" },
      "foreground-subtle":    { "$value": "{primitive.color.stone.500}" },
      "foreground-muted":     { "$value": "{primitive.color.stone.400}" },
      "foreground-secondary": { "$value": "{primitive.color.stone.600}" },
      "border":               { "$value": "{primitive.color.stone.200}" },
      "border-strong":        { "$value": "{primitive.color.stone.300}" },
      "primary":              { "$value": "{primitive.color.stone.800}" },
      "primary-hover":        { "$value": "{primitive.color.stone.900}" },
      "primary-foreground":   { "$value": "{primitive.color.stone.0}" },
      "secondary":            { "$value": "{primitive.color.stone.200}" },
      "secondary-hover":      { "$value": "{primitive.color.stone.300}" },
      "secondary-foreground": { "$value": "{primitive.color.stone.900}" },
      "destructive":          { "$value": "{primitive.color.brick.600}" },
      "destructive-hover":    { "$value": "{primitive.color.brick.700}" },
      "destructive-foreground": { "$value": "{primitive.color.stone.0}" },
      "success":              { "$value": "{primitive.color.sage.600}" },
      "warning":              { "$value": "{primitive.color.amber.600}" },
      "info":                 { "$value": "{primitive.color.slate.600}" },
      "focus-ring":           { "$value": "{primitive.color.stone.700}" },
      "primary-active":       { "$value": "{primitive.color.stone.950}" },
      "secondary-active":     { "$value": "{primitive.color.stone.300}" },
      "destructive-active":   { "$value": "{primitive.color.brick.700}" },
      "success-subtle":       { "$value": "{primitive.color.sage.50}" },
      "success-foreground":   { "$value": "{primitive.color.sage.700}" },
      "warning-subtle":       { "$value": "{primitive.color.amber.50}" },
      "warning-foreground":   { "$value": "{primitive.color.amber.700}" },
      "destructive-subtle":   { "$value": "{primitive.color.brick.50}" }
    }
  }
}
